		{"id":"095c2ef04652f093","x":9320,"y":1097,"width":250,"height":95,"type":"text","text":"Kill of The hand (Jon Arryn)\nPoison"},
		{"id":"b1f44b21af26994f","x":9860,"y":1115,"width":250,"height":60,"type":"text","text":"Ned turns to be the Hand"},
		{"id":"9377c89bb8702e0c","x":9208,"y":1280,"width":474,"height":140,"type":"text","text":"Jon Arryn was poisoned by his own wife, ==**Lysa Arryn**==, acting on the orders and manipulation of **Petyr \"Littlefinger\" Baelish**\n\nAnd to Blame the Lannisters with the card post to Catelyn"}
	],
